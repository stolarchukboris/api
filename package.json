  "license": "MIT",
  "dependencies": {
    "express": "^5.2.1",
    "knex": "^3.1.0",
    "mysql2": "^3.16.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/express": "^5.0.6"
  }
}
