{
  "name": "api",
  "version": "2.0.0",
  "description": "My testing API",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "type": "module",
  "scripts": {
    "processStart": "pm2 start . --interpreter bun --name API",
    "processRestart": "bun stop && bun processStart",
    "start": "bun processStart && pm2 logs",
    "restart": "bun processRestart && pm2 logs",
    "stop": "pm2 delete ."
  },
